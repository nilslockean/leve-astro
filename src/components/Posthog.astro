<script>
  import posthog from "posthog-js";
  import { POSTHOG_PROJECT_API_KEY } from "astro:env/client";

  posthog.init(POSTHOG_PROJECT_API_KEY, {
    api_host: "https://eu.i.posthog.com",
    defaults: "2026-01-30",
  });

  // Set Distinct ID in cookie so that the server can track the user across sessions
  const distinctId = posthog.get_distinct_id();
  document.cookie = `ph_distinct_id=${distinctId};`;
</script>
