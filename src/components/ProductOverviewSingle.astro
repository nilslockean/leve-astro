---
import type { Product } from "@lib/schemas/Product";
import { Image } from "astro:assets";
import { urlFor } from "@lib/sanityAPI";
import { formatPrice } from "@lib/stringUtils";
import { getProductUrl } from "@config/site";
import Card from "./Card.astro";

interface Props {
  product: Product;
  availablePickupDates: string[];
}

const { product, availablePickupDates } = Astro.props;
const featuredImage = product.images[0];
const prices = product.variants.map(({ price }) => price);
const outOfStock = product.maxQuantityPerOrder === 0;
const noPickupDatesAvailable = availablePickupDates.length === 0;
const buttonLabel = outOfStock
  ? "Slut i lager"
  : noPickupDatesAvailable
    ? "Ej tillgänglig"
    : "Beställ";
---

<Card
  linked
  title={product.title}
  stacked
  data-variants-count={product.variants.length}
  data-available={!outOfStock && availablePickupDates.length > 0}
  data-product-id={product.id}
>
  <p data-translate="never">{formatPrice(prices)}</p>
  <Image
    src={urlFor(featuredImage.asset).width(770).height(580).url()}
    alt={featuredImage.alt}
    inferSize
    slot="image"
  />
  <a
    href={getProductUrl(product.id)}
    slot="actions"
    class="btn btn--small"
    data-testid="product-overview-link">{buttonLabel}</a
  >
</Card>

<style>
  :global(.card__body) {
    row-gap: calc(var(--spacing) * 4);
  }

  :global(.card__title) {
    margin-bottom: calc(var(--spacing) * 1);
  }
</style>
