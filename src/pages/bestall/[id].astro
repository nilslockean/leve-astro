---
import Layout from "../../layouts/Layout.astro";
import { getEntry } from "astro:content";
import ProductDetail from "@components/ProductDetail/index.astro";
import { ENABLE_STOREFRONT } from "astro:env/server";
import { getPickupDatesForProducts } from "@lib/pickupDates";
import { captureEvent } from "@lib/posthogServer";

export const prerender = false;

if (!ENABLE_STOREFRONT) {
  return Astro.rewrite("/404");
}

const { id = "" } = Astro.params;
const entry = await getEntry("products", id);

if (!entry) {
  return Astro.rewrite("/404");
}

captureEvent("Product Viewed", Astro.cookies, {
  product_id: entry.data.id,
  name: entry.data.title,
});

const availablePickupDates = await getPickupDatesForProducts(entry.data);
---

<Layout
  title={entry.data.title}
  metaDescription="Beställ dina fredagsmunkar i förväg och hämta enkelt upp vid vald tid."
>
  <ProductDetail product={entry.data} {availablePickupDates} />
</Layout>
